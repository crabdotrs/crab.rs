{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Crab",
  "scopeName": "source.crab",
  "fileTypes": [".crab"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.crab",
          "match": "//.*$"
        },
        {
          "name": "comment.block.crab",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.documentation.crab",
          "begin": "/\\*\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.crab",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.crab",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.crab",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.crab",
              "match": "\\\\."
            },
            {
              "name": "constant.other.placeholder.crab",
              "match": "\\$\\{[^}]*\\}"
            }
          ]
        },
        {
          "name": "string.quoted.triple.crab",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.crab",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.crab",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.float.crab",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.hex.crab",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.crab",
          "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|try|catch|finally|throw|async|await|yield)\\b"
        },
        {
          "name": "keyword.declaration.crab",
          "match": "\\b(var|final|const|class|abstract|sealed|base|interface|extension|mixin|enum|typedef|import|export|part|partOf|library)\\b"
        },
        {
          "name": "keyword.other.crab",
          "match": "\\b(static|final|const|required|factory|override|get|set|this|super|new|is|as|in|on|with|show|hide|deferred|unsafe|defer)\\b"
        },
        {
          "name": "constant.language.crab",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.crab",
          "match": "\\b(int|double|bool|String|void|dynamic|Never|Future|Stream|List|Map|Set|Result|Option)\\b"
        },
        {
          "name": "storage.type.crab",
          "match": "\\b(class|enum|typedef|extension|mixin|interface)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.crab",
          "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "entity.name.function.crab" },
            "2": { "name": "punctuation.definition.parameters.begin.crab" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.parameters.end.crab" }
          },
          "patterns": [
            { "include": "#parameters" }
          ]
        }
      ]
    },
    "parameters": {
      "patterns": [
        {
          "name": "variable.parameter.crab",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.crab",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.crab",
          "match": "(=|\\+=|-=|\\*=|/=|%=|\\?\\?=)"
        },
        {
          "name": "keyword.operator.comparison.crab",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.crab",
          "match": "(\\+|-\\*\\*|\\*|/|~/%|\\+\\+|--)"
        },
        {
          "name": "keyword.operator.logical.crab",
          "match": "(&&|\\|\\||!|&)"
        },
        {
          "name": "keyword.operator.bitwise.crab",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.null-aware.crab",
          "match": "(\\?\\.|\\?\\?)"
        },
        {
          "name": "keyword.operator.ternary.crab",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.arrow.crab",
          "match": "(=>|->)"
        }
      ]
    }
  }
}
