{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "crab",
      "camelcase": "Crab",
      "title": "Crab",
      "scope": "source.crab",
      "file-types": [
        "crab"
      ],
      "injection-regex": "^crab$",
      "class-name": "TreeSitterCrab"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "treesitter grammer for crab language",
    "authors": [
      {
        "name": "crabdotrs",
        "email": "irustenjoyer@proton.me",
        "url": "https://github.com/irustenjoyer"
      }
    ],
    "links": {
      "repository": "https://github.com/crabdotrs/crab.rs",
      "funding": "https://github.com/crabdotrs/crab.rs"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}