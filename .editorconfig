root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.crab]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{md,mdx}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.{js,ts,tsx}]
indent_style = space
indent_size = 2
