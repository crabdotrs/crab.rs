/// A sample library function
/// 
/// Example:
/// ```crab
/// var result = add(2, 3);
/// print(result); // 5
/// ```
int add(int a, int b) {
  return a + b;
}

/// A sample class
class Calculator {
  int value;

  Calculator(this.value);

  int add(int n) {
    value += n;
    return value;
  }

  int multiply(int n) {
    value *= n;
    return value;
  }
}
